{
  "format": "kdna-cluster",
  "format_version": "0.9.0",
  "cluster_id": "@fixture/reference-cluster",
  "name": "Reference Cluster Fixture",
  "version": "1.0.0",
  "description": "Valid infrastructure fixture; it makes no content or behavior claim.",
  "type": "vertical",
  "status": "draft",
  "access": "public",
  "domains": [
    {
      "id": "@fixture/primary",
      "version": "^1.0.0",
      "role": "primary-candidate",
      "required": true,
      "load_condition": "Use for the primary fixture decision."
    },
    {
      "id": "@fixture/advisor",
      "version": "^1.0.0",
      "role": "advisor",
      "required": false,
      "load_condition": "Use when an independent fixture dimension is requested.",
      "contribution_hypothesis_template": "Adds an independent fixture dimension not covered by the primary."
    }
  ],
  "composition": {
    "strategy": "signal_based",
    "max_active_domains": 2,
    "conflict_policy": "surface",
    "priority_order": ["@fixture/primary", "@fixture/advisor"],
    "primary_selection": "exactly_one",
    "advisor_selection": "contribution_hypothesis_required"
  },
  "budget": {
    "profile": "interactive",
    "max_tokens": 400,
    "max_assets": 2,
    "enforcement": "hard"
  }
}
