  "composition": {
    "strategy": "signal_based",
    "max_active_domains": 3,
    "conflict_policy": "surface",
    "priority_order": [
      "@aikdna/creator-brand-positioning",
      "@aikdna/creator-topic-selection",
      "@aikdna/creator-originality-judgment",
      "@aikdna/creator-publishing-rhythm",
      "@aikdna/creator-content-depth",
      "@aikdna/creator-audience-signal"
    ],
    "primary_selection": "exactly_one",
    "advisor_selection": "contribution_hypothesis_required"
  },
  "budget": {
    "profile": "interactive",
    "max_tokens": 800,
    "max_chars": 2500,
    "max_assets": 3,
    "enforcement": "hard"
  },
  "degradation_policy": {
    "primary_unavailable": "block",
    "required_advisor_unavailable": "block",
    "optional_advisor_unavailable": "continue_with_warning",
    "budget_exceeded": "block"
  },
  "relationships": [
    {
      "from": "@aikdna/creator-brand-positioning",
      "to": "@aikdna/creator-topic-selection",
      "type": "constrains",
      "description": "A topic may extend the position but should not silently redefine its audience or value."
    },
    {
      "from": "@aikdna/creator-content-depth",
      "to": "@aikdna/creator-topic-selection",
      "type": "informs",
      "description": "Feasible depth and evidence burden affect whether a topic is worth committing to now."
    },
    {
      "from": "@aikdna/creator-content-depth",
      "to": "@aikdna/creator-originality-judgment",
      "type": "informs",
      "description": "Depth tests whether a distinct claim is sufficiently developed for its audience."
    },
    {
      "from": "@aikdna/creator-audience-signal",
      "to": "@aikdna/creator-brand-positioning",
      "type": "informs",
      "description": "Repeated audience evidence can test whether intended positioning is actually perceived."
    },
    {
      "from": "@aikdna/creator-audience-signal",
      "to": "@aikdna/creator-publishing-rhythm",
      "type": "informs",
      "description": "Objective-matched response data can reveal whether cadence is degrading quality or expectation."
    }
  ]
